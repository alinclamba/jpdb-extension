{
  "manifest_version": 3,
  "name": "JPDB Snippet Generator",
  "version": "1.0",
  "description": "Generate and copy JPDB status snippets for Jetpack support.",
  "action": {
    "default_popup": "popup.html",
    "default_title": "JPDB Snippet Generator"
  },
  "permissions": ["clipboardWrite"],
  "host_permissions": ["https://jptools.wordpress.com/*"]
}
